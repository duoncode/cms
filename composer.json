{
	"name": "duon/cms",
	"description": "Duon content management system and framework",
	"type": "library",
	"license": "MIT",
	"authors": [
		{
			"name": "Ernst",
			"email": "ernst@duon.sh"
		}
	],
	"homepage": "https://duon.sh/cms",
	"minimum-stability": "dev",
	"prefer-stable": true,
	"require": {
		"php": "^8.5",
		"ext-pgsql": "*",
		"ext-gd": "*",
		"ext-intl": "*",
		"ext-curl": "*",
		"ext-dom": "*",
		"ext-xml": "*",
		"duon/boiler": "^0.3.3",
		"duon/core": "dev-main",
		"duon/error": "^0.1",
		"duon/quma": "^0.1",
		"duon/session": "^0.1",
		"duon/sire": "^0.3",
		"gumlet/php-image-resize": "2.0.*",
		"hidehalo/nanoid-php": "^2",
		"psr/log": "^3.0",
		"vlucas/phpdotenv": "^5.6"
	},
	"require-dev": {
		"duon/dev": "^3.0",
		"filp/whoops": "^2.15",
		"laminas/laminas-diactoros": "^3"
	},
	"suggest": {
		"filp/whoops": "Enables pretty debug error pages in debug mode."
	},
	"autoload": {
		"psr-4": {
			"Duon\\Cms\\": "src"
		},
		"files": [
			"src/Util/Functions.php"
		]
	},
	"autoload-dev": {
		"psr-4": {
			"Duon\\Cms\\Tests\\": "tests"
		}
	},
	"scripts": {
		"test": "./vendor/bin/phpunit --testdox --no-coverage --colors=always",
		"mdlint": "markdownlint-cli2 README.md CHANGELOG.md LICENSE.md",
		"lint": [
			"./vendor/bin/mago fmt --check",
			"./vendor/bin/mago lint"
		],
		"coverage": [
			"php -d xdebug.mode=coverage ./vendor/bin/phpunit --testdox --path-coverage --coverage-text --coverage-php=.coverage/cover.php --colors=always",
			"./vendor/bin/coverlyzer .coverage/cover.php"
		],
		"ci": [
			"composer lint",
			"composer coverage",
			"composer mdlint"
		]
	}
}
